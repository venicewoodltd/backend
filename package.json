{
  "name": "venicewood-backend-production",
  "version": "1.0.0",
  "description": "Venice Wood Ltd - Production Backend API Server",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "cross-env NODE_ENV=development node --watch server.js",
    "maintenance:health": "node maintenance/healthCheck.js",
    "maintenance:security": "node maintenance/securityAudit.js",
    "maintenance:db-integrity": "node maintenance/dbIntegrity.js",
    "maintenance:gridfs-cleanup": "node maintenance/gridfsCleanup.js",
    "maintenance:backup": "node maintenance/backup.js",
    "maintenance:token-cleanup": "node maintenance/tokenCleanup.js",
    "maintenance:performance": "node maintenance/performanceCheck.js",
    "maintenance:log-rotate": "node maintenance/logRotation.js",
    "maintenance:full-check": "node maintenance/fullSystemCheck.js",
    "seed": "node scripts/seed.js",
    "create-admin": "node scripts/createDefaultAdmin.js",
    "backup": "node scripts/daily-backup.js",
    "backup:daily": "node scripts/daily-backup.js"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "graphql": "^16.10.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.12.0",
    "mongoose": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^7.0.11",
    "pg": "^8.14.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "sharp": "^0.34.5",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
